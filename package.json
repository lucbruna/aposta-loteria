    "concurrently": "^10.0.3",
    "jsdom": "^29.1.1",
    "typescript": "^5.8.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "chart.js": "^4.5.1"
  }
