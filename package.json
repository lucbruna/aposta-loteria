{
  "name": "loterias-brasil-ia",
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:all": "concurrently -n fe,api -c cyan,green \"vite\" \"npm run api\"",
    "api": "cd server && npx tsx index.ts",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "typecheck:api": "cd server && npx tsc --noEmit",
    "analyze": "vite-bundle-visualizer",
    "lint": "eslint . && tsc --noEmit && vitest run",
    "lint:ts": "eslint .",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "@types/pako": "^2.0.4",
    "concurrently": "^10.0.3",
    "eslint": "^10.4.1",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.7",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.60.1",
    "vite": "^6.0.0",
    "vite-bundle-visualizer": "^1.2.1",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^3.0.0"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "vitest run --bail 1 --reporter=verbose --"
    ]
  },
  "dependencies": {
    "idb-keyval": "^6.2.5",
    "pako": "^2.1.0",
    "uplot": "^1.6.32"
  }
}
